# .env.example - Copiar como .env.local para configuración local

# Base de Datos
DB_HOST=localhost
DB_PORT=3306
DB_NAME=academic_path
DB_USERNAME=root
DB_PASSWORD=tu_contraseña_segura

# JPA/Hibernate
HIBERNATE_DIALECT=org.hibernate.dialect.MySQL8Dialect
DDL_AUTO=update
SHOW_SQL=false

# Servidor
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api

# Logging
LOG_LEVEL=INFO
LOG_LEVEL_SPRING=INFO
LOG_LEVEL_HIBERNATE=WARN

# Security
JWT_SECRET=tu_secreto_jwt_super_seguro_y_largo
JWT_EXPIRATION=3600000

# Spring Profile
SPRING_PROFILES_ACTIVE=local

